# ─────────────────────────────────────────────────────────────
#  Genshin Pick System — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit the .env file to version control.
# ─────────────────────────────────────────────────────────────

# JWT Secret Key — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-chars

# JWT token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# SQLite database path (relative to backend/ directory)
DATABASE_URL=sqlite:///./genshin_draft.db

# App environment: "development" or "production"
APP_ENV=development

# Security: Set to True in production to disable sensitive logs/endpoints
PROD=False

# CORS: List of allowed domains. Use ["*"] for public dev, 
# or specific domains like ["https://myapp.vercel.app"] in production.
ALLOWED_ORIGINS=["*"]
