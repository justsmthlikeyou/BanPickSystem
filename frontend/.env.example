# ─────────────────────────────────────────────────────────────
#  Genshin Pick System — Frontend Configuration
#  Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────

# API Base URL (e.g. https://your-backend-render-app.onrender.com)
# LEAVE EMPTY in development if using the Vite proxy.
VITE_API_URL=

# WebSocket Base URL (e.g. your-backend-render-app.onrender.com)
# LEAVE EMPTY in development if using the Vite proxy.
VITE_WS_URL=
